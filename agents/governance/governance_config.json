{
  "no_pii": {
    "description": "Block any personally identifiable information",
    "block_keywords": ["cpf", "cnpj", "email", "phone", "endereço"],
    "enforcement_rule": "True\n# placeholder: sandbox rule would inspect context for PII\n"
  },
  "no_toxic": {
    "description": "Block toxic language",
    "block_keywords": ["hate", "kill", "violence", "ódio", "matar", "violência"],
    "enforcement_rule": "True\n"
  },
  "no_prompt_injection": {
    "description": "Block prompt injection attempts",
    "block_keywords": ["ignore previous", "system prompt", "override", "bypass"],
    "enforcement_rule": "True\n"
  },
  "resource_limit": {
    "description": "Enforce resource usage limits",
    "block_keywords": [],
    "enforcement_rule": "ctx.get('tokens', 0) < 4000\n"
  }
}